<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Annapurna Circuit</title>

    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">

    <link rel="stylesheet" href="/Stylesheets/css_home/libs.bundle.css" />
    <link rel="stylesheet" href="/Stylesheets/css_home/theme.bundle.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #111111;
            color: #ffffff;
            margin: 0;
            padding: 0;
        }

        nav.navbar {
            transition: background-color 0.3s ease, color 0.3s ease;
            background-color: transparent !important;
            padding-top: 0 !important;
        }

        nav.navbar .nav-link,
        nav.navbar .navbar-brand,
        nav.navbar i,
        nav.navbar span {
            color: #ffffff !important;
            transition: color 0.3s ease;
        }

        nav.navbar:hover {
            background-color: #ffffff !important;
        }

        nav.navbar:hover .nav-link,
        nav.navbar:hover .navbar-brand,
        nav.navbar:hover i,
        nav.navbar:hover span {
            color: #000000 !important;
        }

        .annapurna-content {
            position: relative;
            max-width: 1200px;
            margin: 150px auto 50px auto;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 40px;
            align-items: flex-start;
        }

        .annapurna-image {
            flex: 0 0 300px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .annapurna-image img {
            width: 100%;
            border-radius: 0;
        }

        .annapurna-text {
            flex: 1;
            font-size: 1.1rem;
            line-height: 1.6;
            color: #ccc;
        }

        .annapurna-video {
            flex: 1;
            min-width: 300px;
        }

        .annapurna-video iframe {
            width: 100%;
            max-width: 100%;
        }

        .wanttogo-btn button {
            border: 2px solid #5d3eff;
            color: #5d3eff;
            background: transparent;
            border-radius: 0;
            padding: 10px;
            font-weight: 600;
            cursor: pointer;
        }

        .wanttogo-btn button:hover {
            background-color: #5d3eff;
            color: white;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg border-0 position-absolute top-0 start-0 w-100 z-index-30">
    <div class="w-100 pb-lg-0 pt-lg-0 pt-4 pb-3">
        <div class="container-fluid d-flex justify-content-between align-items-center flex-wrap">

            <a class="navbar-brand fw-bold fs-3 m-0 p-0 flex-shrink-0" href="/home">
                <div class="d-flex align-items-center">
                    <span class="fs-5">Annapurna Circuit</span>
                </div>
            </a>

            <div class="ms-5 flex-shrink-0 collapse navbar-collapse navbar-collapse-light w-auto flex-grow-1" id="navbarNavDropdown">
                <ul class="navbar-nav py-lg-2 mx-auto">
                    <li class="nav-item me-lg-4"><a class="nav-link fw-bolder py-lg-4" href="/home">Home</a></li>
                    <li class="nav-item me-lg-4"><a class="nav-link fw-bolder py-lg-4" href="/wanttogo">Want To Go</a></li>
                    <li class="nav-item dropdown me-lg-4">
                        <a class="nav-link fw-bolder dropdown-toggle py-lg-4" href="#" data-bs-toggle="dropdown">Categories</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/hiking">Hiking</a></li>
                            <li><a class="dropdown-item" href="/islands">Islands</a></li>
                            <li><a class="dropdown-item" href="/cities">Cities</a></li>
                        </ul>
                    </li>
                </ul>
            </div>

        </div>
    </div>
</nav>

<div class="annapurna-content">
    <div class="annapurna-image">
        <img src="/images/annapurna.png" alt="Annapurna Circuit">

        <!-- ✅ FIXED FORM -->
        <form method="POST" action="/want-to-go" class="wanttogo-btn">
            <input type="hidden" name="slug" value="annapurna">
            <button type="submit" class="btn btn-sm w-100">
                Add to Want to Go
            </button>
        </form>
    </div>

    <div class="annapurna-text">
        <p>
            Annapurna Circuit has been voted as the best long-distance trek in the world.
            It features a wide range of climates, from tropical forests to arctic terrain,
            and rich cultural diversity from Hindu villages to Tibetan communities.
        </p>
    </div>

    <div class="annapurna-video">
        <iframe height="315"
                src="https://www.youtube.com/embed/6OTUR1NScKM"
                title="Annapurna Circuit video"
                allowfullscreen>
        </iframe>
    </div>
</div>

<script src="/javascript/js_home/vendor.bundle.js"></script>
<script src="/javascript/js_home/theme.bundle.js"></script>

</body>
</html>
