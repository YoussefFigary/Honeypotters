<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rome</title>

    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">

    <link rel="stylesheet" href="/Stylesheets/css_home/libs.bundle.css">
    <link rel="stylesheet" href="/Stylesheets/css_home/theme.bundle.css">

    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #111111;
            color: #ffffff;
            margin: 0;
            padding: 0;
        }

        nav.navbar {
            background-color: transparent !important;
            transition: background-color 0.3s ease;
        }

        nav.navbar .nav-link,
        nav.navbar .navbar-brand {
            color: #ffffff !important;
        }

        nav.navbar:hover {
            background-color: #ffffff !important;
        }

        nav.navbar:hover .nav-link,
        nav.navbar:hover .navbar-brand {
            color: #000000 !important;
        }

        .rome-content {
            max-width: 1200px;
            margin: 150px auto 50px auto;
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            justify-content: space-between;
            align-items: flex-start;
        }

        .rome-image {
            flex: 0 0 300px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .rome-image img {
            width: 100%;
        }

        .rome-text {
            flex: 1;
            font-size: 1.1rem;
            line-height: 1.6;
            color: #ccc;
        }

        .rome-video {
            flex: 1;
            min-width: 300px;
        }

        .rome-video iframe {
            width: 100%;
            max-width: 100%;
        }

        .wanttogo-btn button {
            border: 2px solid #5d3eff;
            color: #5d3eff;
            background: transparent;
            padding: 10px;
            font-weight: 600;
            cursor: pointer;
        }

        .wanttogo-btn button:hover {
            background-color: #5d3eff;
            color: white;
        }
    </style>
</head>

<body>

 <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-light bg-white border-bottom mx-0 p-0 flex-column border-0 position-absolute w-100 z-index-30 bg-transparent navbar-dark navbar-transparent bg-white-hover transition-all">
        <div class="w-100 pb-lg-0 pt-lg-0 pt-4 pb-3">
            <div class="container-fluid d-flex justify-content-between align-items-center flex-wrap">

                <!-- Logo-->
                <a class="navbar-brand fw-bold fs-3 m-0 p-0 flex-shrink-0" href="/home">
                    <div class="d-flex align-items-center">
                        <div class="f-w-6 d-flex align-items-center me-2 lh-1">
                            <!-- SVG Logo here -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 194 194"><path fill="currentColor" class="svg-logo-white" d="M47.45,60l1.36,27.58,53.41-51.66,50.87,50,3.84-26L194,100.65V31.94A31.94,31.94,0,0,0,162.06,0H31.94A31.94,31.94,0,0,0,0,31.94v82.57Z"/><path fill="currentColor" class="svg-logo-dark" d="M178.8,113.19l1,34.41L116.3,85.92l-14.12,15.9L88.07,85.92,24.58,147.53l.93-34.41L0,134.86v27.2A31.94,31.94,0,0,0,31.94,194H162.06A31.94,31.94,0,0,0,194,162.06V125.83Z"/></svg>
                        </div>
                        <span class="fs-5">HoneyPotters</span>
                    </div>
                </a>

                <!-- Main Navigation-->
                <div class="ms-5 flex-shrink-0 collapse navbar-collapse navbar-collapse-light w-auto flex-grow-1" id="navbarNavDropdown">
                    <button class="btn btn-link px-2 text-decoration-none navbar-toggler border-0 position-absolute top-0 end-0 mt-3 me-2"
                            data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown"
                            aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="ri-close-circle-line ri-2x"></i>
                    </button>

                    <ul class="navbar-nav py-lg-2 mx-auto">
                        <li class="nav-item me-lg-4">
                            <a class="nav-link fw-bolder py-lg-4" href="/home">Home</a>
                        </li>
                        <li class="nav-item me-lg-4">
                            <a class="nav-link fw-bolder py-lg-4" href="/wanttogo">Want To Go</a>
                        </li>
                        <li class="nav-item dropdown me-lg-4">
                            <!-- Top button just toggles dropdown, no href -->
                            <a class="nav-link fw-bolder dropdown-toggle py-lg-4" href="#" role="button" data-bs-toggle="dropdown"
                               aria-haspopup="true" aria-expanded="false">
                                Categories
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/categories">All Categories</a></li>
                                <li><a class="dropdown-item" href="/hiking">Hiking</a></li>
                                <li><a class="dropdown-item" href="/islands">Islands</a></li>
                                <li><a class="dropdown-item" href="/cities">Cities</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>

                <!-- Navbar Icons-->
                <ul class="list-unstyled mb-0 d-flex align-items-center">
                    <li class="d-inline-block d-lg-none">
                        <button class="btn btn-link px-2 text-decoration-none navbar-toggler border-0 d-flex align-items-center"
                                data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown"
                                aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                            <i class="ri-menu-line ri-lg align-middle"></i>
                        </button>
                    </li>

                   <li class="ms-1 d-inline-block">
                        <a href="/searchresults" 
                        class="btn btn-link px-2 text-decoration-none d-flex align-items-center">
                            <i class="ri-search-2-line ri-lg align-middle"></i>
                        </a>
                    </li>

                   

                   
                    
                </ul>

            </div>
        </div>
    </nav>
    <!-- /Navbar -->
<div class="rome-content">
    <div class="rome-image">
        <img src="/images/rome.png" alt="Rome">

        <!-- Fixed backend form -->
        <form method="POST" action="/want-to-go" class="wanttogo-btn">
            <input type="hidden" name="slug" value="rome">
            <button type="submit">Add to Want to Go</button>
        </form>
    </div>

    <div class="rome-text">
        <p>
            Rome today is one of the most important tourist destinations in the world, due to the immense archaeological and art treasures,
            the charm of its unique traditions, the beauty of its panoramic views, and the majesty of its magnificent villas.
        </p>
    </div>

    <div class="rome-video">
        <iframe height="315"
                src="https://www.youtube.com/embed/GXoEpNjgKzg?si=mw2WByO-sxV2MQjw"
                title="Rome video"
                frameborder="0"
                allowfullscreen></iframe>
    </div>
</div>

<script src="/javascript/js_home/vendor.bundle.js"></script>
<script src="/javascript/js_home/theme.bundle.js"></script>

</body>
</html>
