 <!-- Hover Dropdown Fix -->
 <script>
 $(function () {
    if (window.innerWidth > 992) {
        $('.navbar .dropdown').hover(
            function () {
                $(this).addClass('show');
                $(this).find('.dropdown-menu').addClass('show');
            },
            function () {
                $(this).removeClass('show');
                $(this).find('.dropdown-menu').removeClass('show');
            }
        );
    }
 });
 </script>

