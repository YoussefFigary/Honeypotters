<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Results</title>

  <link rel="stylesheet" href="/Stylesheets/css_home/libs.bundle.css">
  <link rel="stylesheet" href="/Stylesheets/css_home/theme.bundle.css">
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- SEARCH FORM (POST) -->
  <section class="py-5">
    <div class="container search-container">
      <div class="py-5">
        <form action="/search" method="POST">
          <input type="text" name="search" class="form-control mb-4" placeholder="Please enter a Destination" required>
        </form>

        <!-- RESULTS TITLE -->
        <p class="lead fw-bolder" id="resultsTitle">
          <% if (query) { %>
            Showing results for <span class="fw-bold">"<%= query %>"</span>
          <% } else { %>
            Welcome! Please enter a search term.
          <% } %>
        </p>

        <!-- RESULTS CARDS -->
        <div class="row" id="resultsContainer">
          <% if (results && results.length > 0) { %>
            <% results.forEach(function(item){ %>
              <div class="col-12 col-md-6 col-lg-3 mb-3">
                <div class="card h-100 text-center">
                  <div class="card-header bg-light p-0">
                    <img class="w-100" src="/images/<%= item.name.toLowerCase().replace(/\s+/g,'_') %>.png" alt="<%= item.name %>">
                    <div class="card-actions mt-2">
                      <button class="btn btn-outline-dark btn-sm">Add</button>
                      <button class="btn btn-primary btn-sm" onclick="window.location.href='/<%= item.slug %>'">View</button>
                    </div>
                  </div>
                  <div class="card-body">
                    <h5 class="card-title"><%= item.name %></h5>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else if (message) { %>
            <p><%= message %></p>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <script src="/javascript/js_home/vendor.bundle.js"></script>
  <script src="/javascript/js_home/theme.bundle.js"></script>
</body>
</html>
